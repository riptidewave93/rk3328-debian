From bd63cbd1111c6dc5fcfd83bdee86e4d49b97dba3 Mon Sep 17 00:00:00 2001
From: Chris Blake <chrisrblake93@gmail.com>
Date: Sun, 31 Jan 2021 13:58:55 -0600
Subject: [PATCH 8/8] arm64: dts: rockchip: enable usb3 on nanopi rk3328 boards

---
 .../boot/dts/rockchip/rk3328-nanopi-neo3.dts  | 21 +++++++++++++++++++
 .../boot/dts/rockchip/rk3328-nanopi-r2s.dts   | 21 +++++++++++++++++++
 2 files changed, 42 insertions(+)

diff --git a/arch/arm64/boot/dts/rockchip/rk3328-nanopi-neo3.dts b/arch/arm64/boot/dts/rockchip/rk3328-nanopi-neo3.dts
index afeb8ba7f60b..051ae5ed90d2 100644
--- a/arch/arm64/boot/dts/rockchip/rk3328-nanopi-neo3.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3328-nanopi-neo3.dts
@@ -345,6 +345,27 @@ &uart2 {
   status = "okay";
 };
 
+&usbdrd3 {
+	status = "okay";
+};
+
+&usbdrd_dwc3 {
+	dr_mode = "host";
+	status = "okay";
+};
+
+&usb3phy {
+	status = "okay";
+};
+
+&usb3phy_utmi {
+	status = "okay";
+};
+
+&usb3phy_pipe {
+	status = "okay";
+};
+
 &u2phy {
   status = "okay";
 
diff --git a/arch/arm64/boot/dts/rockchip/rk3328-nanopi-r2s.dts b/arch/arm64/boot/dts/rockchip/rk3328-nanopi-r2s.dts
index 1932b040f0a5..a17bc76a9104 100644
--- a/arch/arm64/boot/dts/rockchip/rk3328-nanopi-r2s.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3328-nanopi-r2s.dts
@@ -371,6 +371,27 @@ &tsadc {
 	status = "okay";
 };
 
+&usbdrd3 {
+	status = "okay";
+};
+
+&usbdrd_dwc3 {
+	dr_mode = "host";
+	status = "okay";
+};
+
+&usb3phy {
+	status = "okay";
+};
+
+&usb3phy_utmi {
+	status = "okay";
+};
+
+&usb3phy_pipe {
+	status = "okay";
+};
+
 &u2phy {
 	status = "okay";
 };
