From 5af78e166fad0196183ddde65624f8968e87cd31 Mon Sep 17 00:00:00 2001
From: Chris Blake <chrisrblake93@gmail.com>
Date: Sun, 31 Jan 2021 13:53:48 -0600
Subject: [PATCH 1/8] arm64: dts: rk3328: update nanopi r2s dts

* Add the rtl8153 regulator
* Fixup the ethernet driver compatible, since it can fail to identify
otherwise.
* Minor name & led adjustments
---
 .../boot/dts/rockchip/rk3328-nanopi-r2s.dts   | 35 ++++++++++++++++++-
 1 file changed, 34 insertions(+), 1 deletion(-)

diff --git a/arch/arm64/boot/dts/rockchip/rk3328-nanopi-r2s.dts b/arch/arm64/boot/dts/rockchip/rk3328-nanopi-r2s.dts
index 2ee07d15a6e3..1932b040f0a5 100644
--- a/arch/arm64/boot/dts/rockchip/rk3328-nanopi-r2s.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3328-nanopi-r2s.dts
@@ -11,7 +11,7 @@
 
 / {
 	model = "FriendlyElec NanoPi R2S";
-	compatible = "friendlyarm,nanopi-r2s", "rockchip,rk3328";
+	compatible = "friendlyelec,nanopi-r2s", "rockchip,rk3328";
 
 	chosen {
 		stdout-path = "serial2:1500000n8";
@@ -24,6 +24,18 @@ gmac_clk: gmac-clock {
 		#clock-cells = <0>;
 	};
 
+	vcc_rtl8153: vcc-rtl8153-regulator {
+		compatible = "regulator-fixed";
+		gpio = <&gpio2 RK_PC6 GPIO_ACTIVE_HIGH>;
+		pinctrl-names = "default";
+		pinctrl-0 = <&rtl8153_en_drv>;
+		regulator-always-on;
+		regulator-name = "vcc_rtl8153";
+		regulator-min-microvolt = <5000000>;
+		regulator-max-microvolt = <5000000>;
+		enable-active-high;
+	};
+
 	keys {
 		compatible = "gpio-keys";
 		pinctrl-0 = <&reset_button_pin>;
@@ -50,6 +62,8 @@ lan_led: led-0 {
 		sys_led: led-1 {
 			gpios = <&gpio0 RK_PA2 GPIO_ACTIVE_HIGH>;
 			label = "nanopi-r2s:red:sys";
+      linux,default-trigger = "default-on";
+      default-state = "on";
 		};
 
 		wan_led: led-2 {
@@ -134,6 +148,8 @@ mdio {
 		#size-cells = <0>;
 
 		rtl8211e: ethernet-phy@1 {
+      compatible = "ethernet-phy-id001c.c915",
+				           "ethernet-phy-ieee802.3-c22";
 			reg = <1>;
 			pinctrl-0 = <&eth_phy_reset_pin>;
 			pinctrl-names = "default";
@@ -144,6 +160,17 @@ rtl8211e: ethernet-phy@1 {
 	};
 };
 
+&i2c0 {
+  status = "okay";
+
+  eeprom: eeprom@51 {
+    compatible = "microchip,24c02", "atmel,24c02";
+    reg = <0x51>;
+    pagesize = <16>;
+    read-only; /* MAC EEPROM */
+  };
+};
+
 &i2c1 {
 	status = "okay";
 
@@ -311,6 +338,12 @@ sdio_vcc_pin: sdio-vcc-pin {
 			rockchip,pins = <1 RK_PD4 RK_FUNC_GPIO &pcfg_pull_up>;
 		};
 	};
+
+	usb {
+		rtl8153_en_drv: rtl8153-en-drv {
+			rockchip,pins = <2 RK_PC6 RK_FUNC_GPIO &pcfg_pull_none>;
+		};
+	};
 };
 
 &pwm2 {
-- 
2.27.0

